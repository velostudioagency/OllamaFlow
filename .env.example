# OllamaFlow Environment Configuration
# Copy this file to .env and fill in the values

# API Authentication (leave empty to disable)
OLLAMAFLOW_API_TOKEN=

# CORS Origins (comma-separated)
OLLAMAFLOW_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Ollama Base URL (use host.docker.internal for Docker)
OLLAMA_BASE_URL=http://localhost:11434

# Groq API Key (optional, for cloud models)
GROQ_API_KEY=

# OpenAI API Key (optional, for OpenAI models)
OPENAI_API_KEY=

# OpenAI Base URL (for compatible APIs)
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic API Key (optional, for Claude models)
ANTHROPIC_API_KEY=

# Search Provider (brave, searxng, or duckduckgo)
SEARCH_PROVIDER=duckduckgo

# Brave Search API Key (if using Brave)
BRAVE_API_KEY=

# SearXNG URL (if using SearXNG)
SEARXNG_URL=

# Firecrawl (self-hosted Docker or cloud API)
FIRECRAWL_URL=http://localhost:3001
FIRECRAWL_API_KEY=
FIRECRAWL_MODE=self_hosted

# Browser-use (LLM provider for AI browser agent)
BROWSER_USE_LLM_PROVIDER=ollama
BROWSER_USE_LLM_MODEL=llama3.1:8b
